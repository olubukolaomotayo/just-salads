rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Each user can read and write ONLY their own document.
    // Nobody, even signed in, can touch another person's data.
    match /users/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId
                         // keep documents to a sane size (1 MB Firestore limit; ours is tiny)
                         && request.resource == null || request.resource.size < 900000;
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
